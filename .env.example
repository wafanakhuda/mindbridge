# ── Gemini AI (required for direct AI calls) ──────────────────
# Get free key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ── n8n Webhook (optional but recommended for full agentic flow)
# Set this to your n8n webhook URL to route ALL agents through n8n
# Format: https://your-n8n-instance.app.n8n.cloud/webhook/mindbridge-triage
# When set: app uses n8n orchestration (Gemini + DB + follow-up)
# When empty: app calls Gemini directly (still works, no DB/follow-up)
VITE_N8N_WEBHOOK_URL=

# ── App URL (set by Railway/Netlify automatically) ─────────────
VITE_APP_URL=http://localhost:3000
