# ── Gemini AI (required for AI agents) ─────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_key_here

# ── MongoDB (required for auth + data persistence) ──────────────
# Free cluster: https://cloud.mongodb.com
# Format: mongodb+srv://user:password@cluster.mongodb.net/mindbridge
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/mindbridge

# ── JWT Secret (change this to a long random string) ────────────
JWT_SECRET=change-this-to-a-long-random-secret-in-production

# ── API URL (where the Express server runs) ─────────────────────
VITE_API_URL=http://localhost:4000/api

# ── App URL ─────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:3000

# ── n8n Webhook (optional) ──────────────────────────────────────
VITE_N8N_WEBHOOK_URL=
